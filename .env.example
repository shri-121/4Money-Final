# ── Copy this file to .env and fill in your values ──────────────────────────

# MongoDB Atlas connection string (get from mongodb.com - free)
MONGO_URL=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=fourmoney_db

# JWT Secret - generate a random string
JWT_SECRET=change-this-to-a-random-long-string-4money-2024

# Gmail SMTP (create App Password at myaccount.google.com/apppasswords)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Your USDT wallet address (TRC20)
PLATFORM_WALLET_ADDRESS=TYourTRC20WalletAddressHere

# Rates
USDT_TO_SC_RATE=106.4
MIN_DEPOSIT_USDT=5
MIN_WITHDRAW_SC=1000

# Admin account (auto-created on startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@4money2024

# Frontend URL for CORS (your Vercel URL)
FRONTEND_URL=https://your-app.vercel.app
